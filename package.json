{
  "name": "http-playground-server-fork",
  "version": "0.0.1",
  "packageManager": "yarn@1.22.22",
  "type": "module",
  "main": "dist/server.js",
  "repository": "https://github.com/ryo8000/http-playground-server-fork.git",
  "author": "Ryo Hasegawa",
  "license": "MIT",
  "engines": {
    "node": ">=26.0.0"
  },
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "newman run tests/e2e/e2e-test-collection.json -e tests/e2e/environment.json --reporters cli",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "verify": "yarn format:check && yarn lint && yarn typecheck"
  },
  "dependencies": {
    "cookie-parser": "1.4.7",
    "express": "5.2.1",
    "pino": "10.3.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "26.1.0",
    "@types/supertest": "7.2.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "jest": "30.4.2",
    "newman": "6.2.2",
    "nodemon": "3.1.14",
    "pino-pretty": "13.1.3",
    "prettier": "3.9.4",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1"
  },
  "resolutions": {
    "flatted": "3.4.2",
    "handlebars": "4.7.9",
    "jose": "4.15.5",
    "lodash": "4.18.0",
    "node-forge": "1.4.0",
    "qs": "6.15.2",
    "underscore": "1.13.8",
    "uuid": "11.1.1"
  }
}

{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git fetch)",
      "Bash(git fetch *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(node dist/server.js)",
      "Bash(yarn install)",
      "Bash(yarn install *)",
      "Bash(yarn dev)",
      "Bash(yarn build)",
      "Bash(yarn test)",
      "Bash(yarn test:*)",
      "Bash(yarn lint)",
      "Bash(yarn lint:*)",
      "Bash(yarn format)",
      "Bash(yarn format:*)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(yarn add *)",
      "Bash(yarn remove *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf /*)",
      "Bash(sudo *)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "enableAllProjectMcpServers": false
}
